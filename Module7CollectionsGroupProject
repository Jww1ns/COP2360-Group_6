using System;
using System.Collections.Generic;
using System.Linq;

namespace Module7Assignment
{
    class Program
    {
        static void Main(string[] args)
        {
            // 1. Initialize a Dictionary with strings as keys and a List of strings as values 
            // This allows us to append multiple values to an existing key.
            Dictionary<string, List<string>> groupDictionary = new Dictionary<string, List<string>>();
            bool running = true;

            while (running)
            {
                Console.WriteLine("\n--- Dictionary Operations Menu ---");
                Console.WriteLine("1. Populate Dictionary (Initial Data)");
                Console.WriteLine("2. Display Dictionary Contents");
                Console.WriteLine("3. Remove a Key");
                Console.WriteLine("4. Add a New Key and Value");
                Console.WriteLine("5. Add a Value to an Existing Key");
                Console.WriteLine("6. Sort the Keys");
                Console.WriteLine("7. Exit");
                Console.Write("Enter your choice (1-7): ");

                string choice = Console.ReadLine();

                // 2. Create a Switch Statement for menu flow
                switch (choice)
                {
                    case "1":
                        // Populate the Dictionary
                        // Using the Add method to populate initial data
                        groupDictionary.Add("Team", new List<string> { "Alice", "Bob" });
                        groupDictionary.Add("Project", new List<string> { "Alpha" });
                        Console.WriteLine("Dictionary populated with initial data.");
                        break;

                    case "2":
                        // Display Dictionary Contents
                        // Using KeyValuePair for enumeration (one of three module-approved enumeration methods)
                        if (groupDictionary.Count == 0)
                        {
                            Console.WriteLine("The dictionary is empty.");
                        }
                        else
                        {
                            Console.WriteLine("Current Dictionary Contents:");
                            foreach (KeyValuePair<string, List<string>> kvp in groupDictionary)
                            {
                                Console.WriteLine($"Key: {kvp.Key} -> Values: {string.Join(", ", kvp.Value)}");
                            }
                        }
                        break;

                    case "3":
                        // Remove a Key
                        Console.Write("Enter the key to remove: ");
                        string keyToRemove = Console.ReadLine();
                        if (groupDictionary.Remove(keyToRemove))
                        {
                            Console.WriteLine($"Key '{keyToRemove}' successfully removed.");
                        }
                        else
                        {
                            Console.WriteLine("Key not found.");
                        }
                        break;

                    case "4":
                        // Add a New Key and Value
                        Console.Write("Enter new key: ");
                        string newKey = Console.ReadLine();
                        Console.Write("Enter the initial value: ");
                        string initialValue = Console.ReadLine();

                        if (!groupDictionary.ContainsKey(newKey))
                        {
                            groupDictionary[newKey] = new List<string> { initialValue };
                            Console.WriteLine($"Key '{newKey}' added with value '{initialValue}'.");
                        }
                        else
                        {
                            Console.WriteLine("That key already exists. Use the Append option to add values.");
                        }
                        break;

                    case "5":
                        // Add a Value to an Existing Key
                        Console.Write("Enter the key to append to: ");
                        string targetKey = Console.ReadLine();
                        if (groupDictionary.TryGetValue(targetKey, out List<string> existingValues))
                        {
                            Console.Write("Enter the new value to add: ");
                            string newValue = Console.ReadLine();
                            existingValues.Add(newValue);
                            Console.WriteLine($"Added '{newValue}' to key '{targetKey}'.");
                        }
                        else
                        {
                            Console.WriteLine("Key not found. Cannot append value.");
                        }
                        break;

                    case "6":
                        // Sort the Keys
                        // LINQ OrderBy() is used to sort the dictionary keys
                        var sortedKeys = groupDictionary.Keys.OrderBy(k => k);
                        Console.WriteLine("Keys sorted alphabetically:");
                        foreach (string key in sortedKeys)
                        {
                            Console.WriteLine($"- {key}");
                        }
                        break;

                    case "7":
                        // Exit the application
                        running = false;
                        Console.WriteLine("Exiting program...");
                        break;

                    default:
                        Console.WriteLine("Invalid input. Please enter a number between 1 and 7.");
                        break;
                }
            }
        }
    }
}
